# Auto-detect text files and normalize line endings to LF on commit.
* text=auto eol=lf

# Source code
*.cs       text diff=csharp
*.csx      text diff=csharp
*.vb       text
*.fs       text
*.fsx      text

# Project / build files
*.csproj   text eol=lf
*.fsproj   text eol=lf
*.vbproj   text eol=lf
*.sln      text eol=crlf
*.slnx     text eol=lf
*.props    text eol=lf
*.targets  text eol=lf

# Config / data
*.json     text eol=lf
*.xml      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.editorconfig text eol=lf
*.gitignore    text eol=lf
*.gitattributes text eol=lf

# Windows-specific scripts
*.cmd      text eol=crlf
*.bat      text eol=crlf
*.ps1      text eol=crlf

# Unix-specific scripts
*.sh       text eol=lf

# Binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.dll      binary
*.exe      binary
*.pfx      binary
*.snk      binary
